{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChegaMed",
  "version": "0.1.0",
  "identifier": "br.com.chegamed",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/desktop/browser"
  },
  "app": {
    "windows": [
      {
        "title": "ChegaMed",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["chegamed-desktop"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "ChegaMed",
    "copyright": "© 2026 ChegaMed",
    "shortDescription": "Sistema de entregas de medicamentos",
    "longDescription": "Projeto focado na entregua de medicamentos publicos em prefeituras. O mesmo tem o papel fundamental em controlar para que os pacientes recebam os medicamentos no tempo correto.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}